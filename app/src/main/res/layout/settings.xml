<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/layout_2"
    tools:context=".Settings">

    <TextView
        android:id="@+id/Settings1Text"
        android:layout_width="403dp"
        android:layout_height="65dp"
        android:text="Możesz zmienić godziny trwania trybu nocnego"
        android:textAlignment="center"
        android:textColor="#3E4C57"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.258" />

    <TextView
        android:id="@+id/EndHourSettingsInput"
        android:layout_width="192dp"
        android:layout_height="48dp"
        android:layout_marginStart="175dp"
        android:gravity="center"
        android:text="08:00"
        android:textColor="#000000"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/StartNightModeSettingsText"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.37"
        tools:ignore="SpeakableTextPresentCheck" />


    <TextView
        android:id="@+id/StartNightModeSettingsText"
        android:layout_width="164dp"
        android:layout_height="35dp"
        android:background="@drawable/rounded_background"
        android:text="POCZĄTEK"
        android:textAlignment="center"
        android:textColor="#3E4C57"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.064"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.363" />

    <TextView
        android:id="@+id/EndNightModeSettingsText"
        android:layout_width="164dp"
        android:layout_height="35dp"
        android:background="@drawable/rounded_background"
        android:text="KONIEC"
        android:textAlignment="center"
        android:textColor="#3E4C57"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.064"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.448" />

    <TextView
        android:id="@+id/StartHourSettingsInput"
        android:layout_width="192dp"
        android:layout_height="48dp"
        android:gravity="center"
        android:text="22:00"
        android:textColor="#000000"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.872"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.456"
        tools:ignore="SpeakableTextPresentCheck" />

    <TextView
        android:id="@+id/Settings2Text"
        android:layout_width="403dp"
        android:layout_height="39dp"
        android:text="Możesz zmienić swoje hasło"
        android:textAlignment="center"
        android:textColor="#3E4C57"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.546" />

    <EditText
        android:id="@+id/SettingsPasswordInput"
        android:layout_width="210dp"
        android:layout_height="50dp"
        android:hint="Hasło"
        android:textColor="#3E4C57"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.98"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="442dp" />


    <EditText
        android:id="@+id/SettingsDuplicatePasswordInput"
        android:layout_width="210dp"
        android:layout_height="50dp"
        android:hint="Potwórz hasło"
        android:textColor="#3E4C57"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.98"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="513dp" />

    <TextView
        android:id="@+id/SettingsPasswordText"
        android:layout_width="164dp"
        android:layout_height="35dp"
        android:background="@drawable/rounded_background"
        android:text="HASŁO"
        android:textAlignment="center"
        android:textColor="#3E4C57"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.064"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.635" />

    <TextView
        android:id="@+id/SetingsDuplicatePasswordText"
        android:layout_width="164dp"
        android:layout_height="54dp"
        android:background="@drawable/rounded_background"
        android:text="POWTÓRZ HASŁO"
        android:textAlignment="center"
        android:textColor="#3E4C57"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.064"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.757" />

    <Button
        android:id="@+id/BackSettingsButton"
        android:layout_width="180dp"
        android:layout_height="50dp"
        android:background="@drawable/rounded_background"
        android:text="POWRÓT"
        android:textColor="#3E4C57"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.982"
        app:layout_constraintStart_toStartOf="parent"
        tools:layout_editor_absoluteY="607dp" />

    <Button
        android:id="@+id/DeleteAccountSettingsButton"
        android:layout_width="180dp"
        android:layout_height="50dp"
        android:background="@drawable/rounded_background"
        android:text="USUŃ KONTO"
        android:textColor="#3E4C57"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.988" />

    <Button
        android:id="@+id/SaveSettingsButton"
        android:layout_width="180dp"
        android:layout_height="50dp"
        android:background="@drawable/rounded_background"
        android:text="ZAPISZ"
        android:textColor="#3E4C57"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.034"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.89" />


</androidx.constraintlayout.widget.ConstraintLayout>