<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/layout_1"
    tools:context=".ActivityMain">


    <Button
        android:id="@+id/logInButtonEnd"
        android:layout_width="180dp"
        android:layout_height="50dp"
        android:layout_marginTop="37dp"
        android:layout_marginBottom="32dp"
        android:backgroundTint="#5DC0AC"
        android:text="ZALOGUJ SIĘ"
        android:textColor="#3E4C57"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/signUpButton1"
        app:layout_constraintVertical_bias="1.0"
        tools:layout_editor_absoluteX="115dp" />

    <Button
        android:id="@+id/signUpButton1"
        android:layout_width="180dp"
        android:layout_height="50dp"
        android:layout_marginTop="124dp"
        android:backgroundTint="#5DC0AC"
        android:text="ZAREJESTRUJ SIĘ"
        android:textColor="#3E4C57"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="@+id/LoginPasswordInput"
        app:layout_constraintVertical_bias="0.0"
        tools:layout_editor_absoluteX="115dp" />

    <TextView
        android:id="@+id/LayoutTextLogin2"
        android:layout_width="317dp"
        android:layout_height="59dp"
        android:text="Witamy w naszej aplikacji do pomiaru natężenia dźwięku!"
        android:textAlignment="center"
        android:textColor="#3E4C57"
        android:textColorLink="#3E4C57"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.416"
        tools:layout_editor_absoluteX="47dp" />

    <TextView
        android:id="@+id/loginEmailText"
        android:layout_width="110dp"
        android:layout_height="45dp"
        android:autoText="false"
        android:background="#925DC0AC"
        android:text="EMAIL"
        android:textAlignment="center"
        android:textColor="#3E4C57"
        android:textColorHint="#3E4C57"
        android:textColorLink="#3E4C57"
        android:textSize="25sp"
        android:textStyle="bold"
        tools:layout_editor_absoluteX="36dp"
        tools:layout_editor_absoluteY="369dp" />

    <TextView
        android:id="@+id/LoginPasswordText"
        android:layout_width="110dp"
        android:layout_height="45dp"
        android:background="#915DC0AC"
        android:text="HASŁO"
        android:textAlignment="center"
        android:textColor="#3E4C57"
        android:textColorHint="#3E4C57"
        android:textColorLink="#3E4C57"
        android:textSize="25sp"
        android:textStyle="bold"
        tools:layout_editor_absoluteX="36dp"
        tools:layout_editor_absoluteY="439dp" />

    <EditText
        android:id="@+id/LoginEmailInput"
        android:layout_width="210dp"
        android:layout_height="50dp"
        android:fontFamily="sans-serif"
        android:hint="Email"
        android:lineSpacingExtra="10sp"
        android:textColor="#3E4C57"
        android:textColorHint="#3E4C57"
        android:textColorLink="#3E4C57"
        tools:ignore="MissingConstraints"
        tools:layout_editor_absoluteX="154dp"
        tools:layout_editor_absoluteY="369dp" />

    <EditText
        android:id="@+id/LoginPasswordInput"
        android:layout_width="210dp"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:ems="10"
        android:fontFamily="sans-serif"
        android:hint="Hasło"
        android:inputType="textPassword"
        android:lineSpacingExtra="10sp"
        android:textColor="#3E4C57"
        android:textColorHint="#3E4C57"
        android:textColorLink="#3E4C57"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/LoginEmailInput"
        app:layout_constraintVertical_bias="0.0"
        tools:layout_editor_absoluteX="154dp" />


</androidx.constraintlayout.widget.ConstraintLayout>