<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/layout_2"
    tools:context=".MainViewApp">


    <TextView
        android:id="@+id/MainViewAppText"
        android:layout_width="387dp"
        android:layout_height="46dp"
        android:text="Aktualne natężenie dźwięku [dB]"
        android:textAlignment="center"
        android:textColor="#3E4C57"
        android:textColorLink="#3E4C57"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.264"
        tools:layout_editor_absoluteX="16dp" />

    <TextView
        android:id="@+id/valueOfDecibelsText"
        android:layout_width="110dp"
        android:layout_height="45dp"
        android:autoText="false"
        android:background="#925DC0AC"
        android:textAlignment="center"
        android:textColor="#3E4C57"
        android:textColorHint="#3E4C57"
        android:textColorLink="#3E4C57"
        android:textSize="25sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.362"
        tools:layout_editor_absoluteX="150dp" />

    <Button
        android:id="@+id/StatisticsButton"
        android:layout_width="180dp"
        android:layout_height="60dp"
        android:backgroundTint="#5DC0AC"
        android:text="STATYSTYKI"
        android:textColor="#3E4C57"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:layout_editor_absoluteX="115dp" />

    <Button
        android:id="@+id/MapsButton"
        android:layout_width="180dp"
        android:layout_height="60dp"
        android:backgroundTint="#5DC0AC"
        android:text="MAPA"
        android:textColor="#3E4C57"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.614"
        tools:layout_editor_absoluteX="115dp" />

    <Button
        android:id="@+id/GuideButton"
        android:layout_width="180dp"
        android:layout_height="60dp"
        android:backgroundTint="#5DC0AC"
        android:text="PORADNIK"
        android:textColor="#3E4C57"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.73"
        tools:layout_editor_absoluteX="115dp" />

    <Button
        android:id="@+id/SettingsButton"
        android:layout_width="180dp"
        android:layout_height="60dp"
        android:backgroundTint="#5DC0AC"
        android:text="USTAWIENIA"
        android:textColor="#3E4C57"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.922"
        tools:layout_editor_absoluteX="16dp" />

    <Button
        android:id="@+id/LogOutButton"
        android:layout_width="180dp"
        android:layout_height="60dp"
        android:backgroundTint="#5DC0AC"
        android:text="WYLOGUJ SIĘ"
        android:textColor="#3E4C57"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.922"
        tools:layout_editor_absoluteX="215dp" />

</androidx.constraintlayout.widget.ConstraintLayout>